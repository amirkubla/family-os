{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "family-os-web",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH && npx expo start --web --port $PORT"],
      "port": 8083,
      "autoPort": true
    },
    {
      "name": "family-os-static",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH && npx serve dist --listen tcp://localhost:$PORT --single"],
      "port": 8084,
      "autoPort": true
    }
  ]
}
