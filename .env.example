# Example env file — copy to .env.development (local dev) or .env.production (Docker build).
# Expo SDK 54 auto-loads .env.<NODE_ENV> based on the command:
#   - `expo start`       → NODE_ENV=development → loads .env.development
#   - `expo export`      → NODE_ENV=production  → loads .env.production
#
# Only EXPO_PUBLIC_* vars are exposed to the frontend bundle.

# Backend API base URL.
# Dev: typically http://localhost:3000 (local backend) or the deployed URL.
# Prod (Docker): leave empty — API calls become same-origin (Hono serves both API and web).
EXPO_PUBLIC_API_URL=

# Public app origin for shareable deep links (invite URLs, etc.).
# Dev: hardcode the deployed URL (share targets are external devices).
# Prod (Docker): leave empty — the JS code falls back to window.location.origin on web.
EXPO_PUBLIC_APP_URL=
